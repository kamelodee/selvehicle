# ── Alibaba Container Registry (ACR) ─────────────────────────────────────────
# Format: registry.cn-<region>.aliyuncs.com
ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ACR_NAMESPACE=your-namespace
ACR_REPO=sel-server
IMAGE_TAG=latest

# ── Alibaba RDS for MySQL ─────────────────────────────────────────────────────
# Use the internal VPC endpoint (rm-xxxx.mysql.rds.aliyuncs.com) so traffic
# stays within the private network and you avoid public egress charges.
RDS_HOST=rm-xxxx.mysql.rds.aliyuncs.com
RDS_PORT=3306
RDS_DB=vehi_db
RDS_USER=vehi_user
RDS_PASSWORD=CHANGE_ME

# ── App settings ─────────────────────────────────────────────────────────────
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_HEX_STRING
TOKEN_EXPIRE_HOURS=8
IDLE_TIMEOUT_SECS=120
LOG_LEVEL=INFO
